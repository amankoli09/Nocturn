{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": ".",
    "composite": true
  },
  "references": [
    { "path": "./api" },
    { "path": "./ui" }
  ],
  "include": ["src/**/*", "scripts/**/*", "test/**/*"]
}